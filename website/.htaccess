# Custom error page
ErrorDocument 404 /404.html

# Correct character encoding
AddDefaultCharset UTF-8

# Force HTTPS and non-www (canonical URLs are https://whygodexists.org/...)
RewriteEngine On
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://whygodexists.org%{REQUEST_URI} [R=301,L]
